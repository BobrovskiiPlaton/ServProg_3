@page
@{
    ViewData["Title"] = "Политика конфиденциальности - Greenswamp";
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
        <div class="flex items-center justify-center space-x-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="text-4xl font-bold text-swamp-900" viewBox="0 0 512 512" style="fill:currentColor" width="48" height="48">
                <path d="M256 0c4.6 0 9.2 1 13.4 2.9L457.7 82.8c22 9.3 38.4 31 38.3 57.2c-.5 99.2-41.3 280.7-213.6 363.2c-16.7 8-36.1 8-52.8 0C57.3 420.7 16.5 239.2 16 140c-.1-26.2 16.3-47.9 38.3-57.2L242.7 2.9C246.8 1 251.4 0 256 0z"/>
            </svg>
            <h1 class="text-4xl font-bold text-swamp-900">Политика конфиденциальности</h1>
        </div>
        <p class="mt-2 text-swamp-800 italic">Последнее обновление: Декабрь 2024</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-8 space-y-8">
        <section class="relative pl-20 min-h-[100px]">
            <div class="absolute left-0 top-0 w-16">
                <div class="bg-swamp-700 rounded-full w-14 h-14 flex items-center justify-center">
                    <span class="text-3xl font-black text-white">1</span>
                </div>
            </div>
            <div>
                <h2 class="text-xl font-semibold text-swamp-900 mb-3">Что мы собираем</h2>
                <p class="text-swamp-800 leading-relaxed">
                    Мы собираем данные — такие как ваш email, IP-адрес и информацию о вашей активности на сайте. 
                    Не волнуйтесь, мы не храним ваши личные рецепты.
                </p>
            </div>
        </section>

        <section class="relative pl-20 min-h-[100px] border-t border-swamp-100 pt-8">
            <div class="absolute left-0 top-8 w-16">
                <div class="bg-swamp-700 rounded-full w-14 h-14 flex items-center justify-center">
                    <span class="text-3xl font-black text-white">2</span>
                </div>
            </div>
            <div>
                <h2 class="text-xl font-semibold text-swamp-900 mb-3">Как мы используем ваши данные</h2>
                <p class="text-swamp-800 leading-relaxed">
                    Используя наши сервисы, вы даете согласие на обработку данных. 
                    Если вам меньше 18 лет, пожалуйста, вернитесь, когда станете совершеннолетним.
                </p>
            </div>
        </section>

        <section class="relative pl-20 min-h-[100px] border-t border-swamp-100 pt-8">
            <div class="absolute left-0 top-8 w-16">
                <div class="bg-swamp-700 rounded-full w-14 h-14 flex items-center justify-center">
                    <span class="text-3xl font-black text-white">3</span>
                </div>
            </div>
            <div>
                <h2 class="text-xl font-semibold text-swamp-900 mb-3">Безопасность</h2>
                <p class="text-swamp-800 leading-relaxed">
                    Мы защищаем ваши данные как дракон свое сокровище. 
                    Оставайтесь бдительными, друзья-лягушки.
                </p>
            </div>
        </section>

        <div class="mt-12 text-center border-t border-swamp-100 pt-8">
            <p class="text-2xl font-semibold text-swamp-700">
                Будьте в безопасности, друзья
                <span class="text-swamp-500">🐸</span>
            </p>
        </div>
    </div>
</div>