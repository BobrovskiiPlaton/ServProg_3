@page
@{
    ViewData["Title"] = "Регистрация";
}

<div class="max-w-md mx-auto px-4 py-12">
    <div class="bg-white rounded-xl shadow-sm p-8">
        <h1 class="text-2xl font-bold text-swamp-900 mb-6 text-center">Регистрация</h1>
        <form>
            <div class="mb-4">
                <input type="text" placeholder="Имя" class="w-full px-4 py-2 border rounded-lg">
            </div>
            <div class="mb-4">
                <input type="email" placeholder="Email" class="w-full px-4 py-2 border rounded-lg">
            </div>
            <div class="mb-6">
                <input type="password" placeholder="Пароль" class="w-full px-4 py-2 border rounded-lg">
            </div>
            <button type="submit" class="w-full bg-swamp-500 text-white py-2 rounded-lg hover:bg-swamp-600">Зарегистрироваться</button>
        </form>
        <p class="mt-4 text-center">Уже есть аккаунт? <a href="/Login" class="text-swamp-600">Войти</a></p>
    </div>
</div>