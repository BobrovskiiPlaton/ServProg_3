@page
@model ContactModel
@{
    ViewData["Title"] = "Контакты - Greenswamp";
}

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-white rounded-xl shadow-sm p-8">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold text-swamp-900 mb-2">
                Связь с нами
            </h2>
            <p class="text-swamp-700">Отправьте сообщение, и оно сразу попадет к нашей команде</p>
        </div>

        <form method="post" class="space-y-6" id="contactForm">
            <!-- Name Field -->
            <div>
                <label class="block text-sm font-medium text-swamp-700 mb-1">
                    Ваше имя
                </label>
                <input type="text" asp-for="Contact.Name" required
                       class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent"
                       placeholder="Ваше имя">
            </div>

            <!-- Email Field -->
            <div>
                <label class="block text-sm font-medium text-swamp-700 mb-1">
                    Ваш Email
                </label>
                <input type="email" asp-for="Contact.Email" required
                       class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent"
                       placeholder="email@example.com">
            </div>

            <!-- Subject Field -->
            <div>
                <label class="block text-sm font-medium text-swamp-700 mb-1">
                    Тема сообщения
                </label>
                <select asp-for="Contact.Subject" class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400">
                    <option>Общий вопрос</option>
                    <option>Сообщить об ошибке</option>
                    <option>Предложение функции</option>
                    <option>Сотрудничество</option>
                </select>
            </div>

            <!-- Message Field -->
            <div>
                <label class="block text-sm font-medium text-swamp-700 mb-1">
                    Ваше сообщение
                </label>
                <textarea asp-for="Contact.Message" rows="5" required
                          class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent"
                          placeholder="Введите ваше сообщение..."></textarea>
            </div>

            <!-- Submit Button -->
            <div class="text-center">
                <button type="submit"
                        class="bg-swamp-500 text-white px-8 py-3 rounded-full font-semibold hover:bg-swamp-600 transition-colors flex items-center justify-center space-x-2 mx-auto shadow-lg">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    <span>Отправить сообщение</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Success Modal -->
<div id="contactSuccess"
     class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-[100]">
    <div class="bg-white rounded-xl max-w-md w-full p-6 relative shadow-lg">
        <div class="text-center">
            <div class="mx-auto w-24 h-24 bg-swamp-100 rounded-full flex items-center justify-center mb-4">
                <img src="~/images/green-toad-wink.svg" alt="The toad approves" class="w-16 h-16">
            </div>
            <h3 class="text-xl font-bold text-swamp-900 mb-2">Сообщение отправлено!</h3>
            <p class="text-swamp-700">
                Мы ответим в течение 24-48 часов.
            </p>
            <button onclick="closeContactSuccess()"
                    class="mt-6 bg-swamp-500 text-white px-6 py-2 rounded-full hover:bg-swamp-600 transition-colors">
                Отлично!
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('contactForm')?.addEventListener('submit', function(e) {
            e.preventDefault();
            if(this.checkValidity()) {
                showContactSuccess();
                this.reset();
            }
        });

        function showContactSuccess() {
            const modal = document.getElementById('contactSuccess');
            if(modal) {
                modal.classList.remove('hidden');
            }
        }

        function closeContactSuccess() {
            const modal = document.getElementById('contactSuccess');
            if(modal) {
                modal.classList.add('hidden');
            }
        }

        document.getElementById('contactSuccess')?.addEventListener('click', (e) => {
            if (e.target === document.getElementById('contactSuccess')) {
                closeContactSuccess();
            }
        });
    </script>
}