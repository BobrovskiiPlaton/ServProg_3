@page
@{
    ViewData["Title"] = "О нас - Greenswamp";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header Section -->
    <div class="text-center mb-16 mt-16">
        <div class="flex items-center justify-center space-x-4">
            <img src="~/images/green-toad-logo.svg" alt="Greenswamp Logo" class="h-20 w-20">
            <h1 class="text-5xl font-bold text-swamp-900">О нашем пруде</h1>
        </div>
        <p class="mt-4 text-lg text-swamp-700 max-w-2xl mx-auto">
            Где связи в кампусе растут как кувшинки!
        </p>
    </div>

    <!-- Story Section -->
    <section class="mb-16">
        <div class="bg-white rounded-xl shadow-sm p-8">
            <div class="flex flex-col md:flex-row items-center gap-8">
                <div class="flex-1">
                    <h2 class="text-3xl font-bold text-swamp-900 mb-4">От головастика к жабе</h2>
                    <p class="text-swamp-700 leading-relaxed">
                        Greenswamp начался как учебный проект в 2023 году, когда наш основатель,
                        Профессор Квак, заметил, что студенты прыгают между слишком многими приложениями.
                        Мы хотели создать один уютный цифровой пруд, где студенческая жизнь могла бы процветать.
                        🐸
                    </p>
                </div>
                <img src="~/images/professor-about.png" alt="Professor Ribbit"
                     class="w-full md:w-1/2 rounded-lg shadow-sm">
            </div>
        </div>
    </section>

    <!-- Values Section -->
    <section class="grid md:grid-cols-3 gap-8 mb-16">
        <div class="bg-white p-6 rounded-xl shadow-sm text-center">
            <div class="w-16 h-16 bg-swamp-100 rounded-full flex items-center justify-center mx-auto">
                <svg class="text-swamp-600 w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                </svg>
            </div>
            <h3 class="mt-4 text-xl font-semibold text-swamp-900">Растем вместе</h3>
            <p class="mt-2 text-swamp-600">Общайтесь между факультетами, клубами и общежитиями</p>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm text-center">
            <div class="w-16 h-16 bg-swamp-100 rounded-full flex items-center justify-center mx-auto">
                <svg class="text-swamp-600 w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
                </svg>
            </div>
            <h3 class="mt-4 text-xl font-semibold text-swamp-900">Безопасное пространство</h3>
            <p class="mt-2 text-swamp-600">Только проверенные аккаунты - никаких хищников в нашем пруду</p>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm text-center">
            <div class="w-16 h-16 bg-swamp-100 rounded-full flex items-center justify-center mx-auto">
                <svg class="text-swamp-600 w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M21 6h-2v2h-2V6h-2V4h2V2h2v2h2v2zm-10 3c1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3 1.34 3 3 3zm0 4c-2.33 0-7 1.17-7 3.5V17h14v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                </svg>
            </div>
            <h3 class="mt-4 text-xl font-semibold text-swamp-900">Веселье</h3>
            <p class="mt-2 text-swamp-600">Пользовательские эмодзи, мероприятия и традиции кампуса</p>
        </div>
    </section>
</div>