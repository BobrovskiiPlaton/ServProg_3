@page
@{
    ViewData["Title"] = "Greenswamp";
}

<div class="relative h-[500px] bg-swamp-800">
    <div class="relative z-10 h-full flex items-center">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <h1 class="text-4xl font-extrabold text-white sm:text-5xl md:text-6xl">
                Добро пожаловать в Greenswamp
            </h1>
            <p class="mt-4 text-lg text-swamp-300">Социальная сеть для студентов</p>
            <div class="mt-5">
                <a href="/Register">
                    <button class="bg-swamp-500 text-white px-8 py-3 rounded-full text-lg font-semibold hover:bg-swamp-600">
                        Присоединиться
                    </button>
                </a>
            </div>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto py-16 px-4">
    <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-xl shadow-sm text-center">
            <h3 class="text-xl font-semibold text-swamp-900">Общайтесь</h3>
            <p class="mt-2 text-swamp-600">Находите друзей по интересам</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm text-center">
            <h3 class="text-xl font-semibold text-swamp-900">Делитесь</h3>
            <p class="mt-2 text-swamp-600">Публикуйте фото и новости</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm text-center">
            <h3 class="text-xl font-semibold text-swamp-900">Участвуйте</h3>
            <p class="mt-2 text-swamp-600">Присоединяйтесь к мероприятиям</p>
        </div>
    </div>
</div>